    const r = Math.random();
    if (r < 0.82) return 'present';
    if (r < 0.90) return 'absent';
    return 'leave';
  });
});

// ─── PAGE TRANSITIONS ───
function goTo(page) {
  const from = document.getElementById('page-' + currentPage);
  const to   = document.getElementById('page-' + page);
  if (!to || page === currentPage) return;
  from.classList.add('exit');
  setTimeout(() => from.classList.remove('active', 'exit'), 450);
  to.classList.add('active');
  currentPage = page;
  setTimeout(() => {
    to.scrollTop = 0;
    if (page === 'home') initCounters();
    if (page === 'dashboard') initDashboard();
  }, 100);
}

function scrollToSection(id) {
  if (currentPage !== 'home') { goTo('home'); setTimeout(() => { const el = document.getElementById(id); if(el) el.scrollIntoView({behavior:'smooth'}); }, 700); }
  else { const el = document.getElementById(id); if(el) el.scrollIntoView({behavior:'smooth'}); }
}

