// ─── STAFF STATS ───
function renderStaffStats() {
  const teachers = STAFF.filter(s => s.type === 'Teacher');
  const nonTeach = STAFF.filter(s => s.type === 'Non-Teaching');
  const active   = STAFF.filter(s => s.status === 'Active');
  const grid = document.getElementById('staff-stats-grid');
  grid.innerHTML = `
    <div class="staff-stat-card"><div class="s-icon">👥</div><div class="s-num">${STAFF.length}</div><div class="s-lbl">Total Staff</div></div>
    <div class="staff-stat-card"><div class="s-icon">🧑‍🏫</div><div class="s-num">${teachers.length}</div><div class="s-lbl">Teachers</div></div>
    <div class="staff-stat-card"><div class="s-icon">🏢</div><div class="s-num">${nonTeach.length}</div><div class="s-lbl">Non-Teaching</div></div>
    <div class="staff-stat-card"><div class="s-icon">✅</div><div class="s-num">${active.length}</div><div class="s-lbl">Active</div></div>
    <div class="staff-stat-card"><div class="s-icon">💰</div><div class="s-num">${formatFRW(STAFF.reduce((a,s)=>a+s.salary,0))}</div><div class="s-lbl">Monthly Payroll</div></div>
    <div class="staff-stat-card"><div class="s-icon">📅</div><div class="s-num">${calcAvgAttendance()}%</div><div class="s-lbl">Avg Attendance</div></div>
  `;
}

function formatFRW(n) {
  if(n >= 1000000) return (n/1000000).toFixed(1) + 'M';
  if(n >= 1000) return (n/1000).toFixed(0) + 'K';
  return n;
}

function calcAvgAttendance() {
  let total = 0, count = 0;
  Object.values(ATTENDANCE).forEach(days => {
    const p = days.filter(d=>d==='present').length;
    total += Math.round((p/days.length)*100);
    count++;
  });
  return count ? Math.round(total/count) : 0;
}

// ─── STAFF TABLE ───
function renderStaffTable() {
  const search = (document.getElementById('staff-search-input')?.value || '').toLowerCase();
  const filterType   = document.getElementById('staff-filter-type')?.value || '';
  const filterStatus = document.getElementById('staff-filter-status')?.value || '';

  let filtered = STAFF.filter(s => {
    const matchSearch = !search || s.name.toLowerCase().includes(search) || s.role.toLowerCase().includes(search) || s.dept.toLowerCase().includes(search);
    const matchType   = !filterType   || s.type === filterType;
    const matchStatus = !filterStatus || s.status === filterStatus;
    return matchSearch && matchType && matchStatus;
  });

  const tbody = document.getElementById('staff-table-body');
  const empty = document.getElementById('staff-empty');

  if(!filtered.length) {
    tbody.innerHTML = '';
    empty.style.display = 'block';
    return;
  }
  empty.style.display = 'none';

  tbody.innerHTML = filtered.map(s => {
    const initials = s.name.split(' ').filter(w=>w.length>1).map(w=>w[0]).join('').toUpperCase().slice(0,2);
    const photoHtml = s.photo
      ? `<img src="${s.photo}" alt="${s.name}">`
      : initials;
    const badgeType   = s.type === 'Teacher' ? 'badge-teacher' : 'badge-staff';
    const badgeStatus = s.status === 'Active' ? 'badge-active' : s.status === 'On Leave' ? 'badge-onleave' : 'badge-inactive';
    return `<tr>
      <td>
        <div class="staff-name-cell">
          <div class="staff-avatar-sm">${photoHtml}</div>
          <div><div class="sname">${s.name}</div><div class="semail">${s.email}</div></div>
        </div>
      </td>
      <td><span class="badge ${badgeType}">${s.type}</span></td>
      <td style="color:var(--white);font-size:0.85rem;">${s.role}</td>
      <td style="color:var(--muted);font-size:0.83rem;">${s.dept}</td>
      <td style="color:var(--muted);font-size:0.83rem;font-family:monospace;">${s.phone}</td>
      <td style="color:var(--muted);font-size:0.83rem;">${formatDate(s.joined)}</td>
      <td><span class="badge ${badgeStatus}">${s.status}</span></td>
      <td>
        <div class="action-btns">
          <button class="action-btn view" title="View Profile" onclick="viewProfile(${s.id})">👤</button>
          <button class="action-btn edit" title="Edit" onclick="openEditModal(${s.id})">✏️</button>
          <button class="action-btn del" title="Delete" onclick="deleteStaff(${s.id})">🗑️</button>
        </div>
      </td>
    </tr>`;
  }).join('');
}

function formatDate(d) {
  if(!d) return '—';
  const dt = new Date(d);
  return dt.toLocaleDateString('en-GB', {day:'2-digit', month:'short', year:'numeric'});
}

