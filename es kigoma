.toast { position: fixed; bottom: 30px; right: 30px; background: #1a3a1a; border: 1px solid rgba(74,222,128,0.3); color: #4ade80; padding: 14px 22px; border-radius: 10px; font-size: 0.88rem; font-weight: 600; z-index: 9999; transform: translateY(80px); opacity: 0; transition: all 0.4s var(--transition); }
