// ─── LOGIN ───
function handleLogin() {
  const user = document.getElementById('login-user').value.trim();
  const pass = document.getElementById('login-pass').value.trim();
  const role = document.getElementById('login-role').value;
  if (!user || !pass || !role) return showToast('Please fill in all fields.', true);
  const acc = ACCOUNTS[user];
  if (!acc || acc.pass !== pass || acc.role !== role) return showToast('Invalid credentials. Try a demo account.', true);
  currentUser = { username: user, role: acc.role, name: acc.name };
  loggedIn = true;
  showToast('Welcome back, ' + acc.name + '! 🎉');
  setTimeout(() => goTo('dashboard'), 800);
}

// ─── REGISTER ───
function handleRegister() {
  const fname = document.getElementById('reg-fname').value.trim();
  const lname = document.getElementById('reg-lname').value.trim();
  const email = document.getElementById('reg-email').value.trim();
  const user  = document.getElementById('reg-user').value.trim();
  const pass  = document.getElementById('reg-pass').value.trim();
  const role  = document.getElementById('reg-role').value;
  if (!fname || !lname || !email || !user || !pass || !role) return showToast('Please fill all fields.', true);
  if (pass.length < 6) return showToast('Password must be at least 6 characters.', true);
  ACCOUNTS[user] = { pass, role, name: fname + ' ' + lname };
  showToast('Account created! You can now log in. ✅');
  setTimeout(() => switchAuthTab('login'), 1200);
}

function doLogout() {
  loggedIn = false;
  currentUser = null;
  showToast('Signed out. See you soon!');
  setTimeout(() => goTo('auth'), 600);
}

