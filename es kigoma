function updateRoleOptions() { /* placeholder for dynamic updates */ }

let pendingPhotoDataUrl = null;
function handlePhotoUpload(e) {
  const file = e.target.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = (ev) => {
    pendingPhotoDataUrl = ev.target.result;
    const box = document.getElementById('photo-preview-box');
    box.innerHTML = `<img src="${pendingPhotoDataUrl}" id="photo-preview-img">`;
  };
  reader.readAsDataURL(file);
}

function saveStaff(isTeacher) {
  const name   = document.getElementById('sf-name')?.value.trim();
  const email  = document.getElementById('sf-email')?.value.trim();
  const role   = document.getElementById('sf-role')?.value;
  const dept   = document.getElementById('sf-dept')?.value;
  const phone  = document.getElementById('sf-phone')?.value.trim();
  const joined = document.getElementById('sf-joined')?.value;
  const qual   = document.getElementById('sf-qual')?.value.trim();
  const status = document.getElementById('sf-status')?.value;
  const salary = parseInt(document.getElementById('sf-salary')?.value) || 300000;

  if(!name || !email) return showToast('Name and email are required.', true);

  if(editingStaffId) {
    const idx = STAFF.findIndex(s => s.id === editingStaffId);
    if(idx !== -1) {
      STAFF[idx] = { ...STAFF[idx], name, email, role, dept, phone, joined, qual, status, salary, photo: pendingPhotoDataUrl || STAFF[idx].photo };
      showToast('Staff record updated successfully! ✅');
    }
  } else {
    const newStaff = { id: staffIdCounter++, name, email, role, dept, phone, joined: joined || new Date().toISOString().split('T')[0], qual, status: status || 'Active', salary, photo: pendingPhotoDataUrl || null, type: isTeacher ? 'Teacher' : 'Non-Teaching' };
    STAFF.push(newStaff);
    ATTENDANCE[newStaff.id] = Array(22).fill('present');
    showToast((isTeacher ? 'Teacher' : 'Staff member') + ' added successfully! 🎉');
  }

  pendingPhotoDataUrl = null;
  closeModal();
  renderStaffStats();
  renderStaffTable();
  renderPayroll();
  renderContracts();
}

function deleteStaff(id) {
  const s = STAFF.find(x => x.id === id);
  if(!s) return;
  if(!confirm(`Delete ${s.name}? This action cannot be undone.`)) return;
  STAFF = STAFF.filter(x => x.id !== id);
  delete ATTENDANCE[id];
  showToast('Staff record deleted.', false);
  renderStaffStats();
  renderStaffTable();
  renderPayroll();
  renderContracts();
}

function closeModal() {
  document.getElementById('staff-modal').classList.remove('open');
  editingStaffId = null;
  pendingPhotoDataUrl = null;
}

