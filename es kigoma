								<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ES Kigoma School</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
:root {
  --navy: #0a1628;
  --deep: #0d1f3c;
  --blue: #1a3a6b;
  --accent: #e8b84b;
  --gold: #f5c842;
  --light: #f0f4ff;
  --white: #ffffff;
  --text: #c8d8f0;
  --muted: #7a92b8;
  --card-bg: rgba(255,255,255,0.04);
  --card-border: rgba(232,184,75,0.18);
  --transition: cubic-bezier(0.77,0,0.175,1);
}
*, *::before, *::after { margin:0; padding:0; box-sizing:border-box; }
html { scroll-behavior: smooth; }
body { font-family: 'DM Sans', sans-serif; background: var(--navy); color: var(--text); overflow-x: hidden; min-height: 100vh; }
body::before { content: ''; position: fixed; inset: 0; background: radial-gradient(ellipse 80% 60% at 20% 10%, rgba(26,58,107,0.55) 0%, transparent 60%), radial-gradient(ellipse 60% 50% at 80% 80%, rgba(232,184,75,0.08) 0%, transparent 55%), radial-gradient(ellipse 40% 40% at 60% 30%, rgba(10,22,40,0.9) 0%, transparent 70%); pointer-events: none; z-index: 0; }

/* PAGE SYSTEM */
.page { position: fixed; inset: 0; overflow-y: auto; opacity: 0; pointer-events: none; transform: translateY(40px); transition: opacity 0.6s var(--transition), transform 0.6s var(--transition); z-index: 1; }
.page.active { opacity: 1; pointer-events: all; transform: translateY(0); z-index: 2; }
.page.exit { opacity: 0; transform: translateY(-40px); pointer-events: none; transition: opacity 0.45s var(--transition), transform 0.45s var(--transition); z-index: 1; }

/* TOPBAR */
.topbar { position: sticky; top: 0; z-index: 999; background: rgba(10,22,40,0.88); backdrop-filter: blur(18px); border-bottom: 1px solid rgba(232,184,75,0.12); padding: 0 40px; display: flex; align-items: center; justify-content: space-between; height: 66px; }
.logo { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 900; color: var(--accent); letter-spacing: 1px; cursor: pointer; transition: color 0.3s; }
.logo span { color: var(--white); }
.nav-links { display: flex; gap: 6px; align-items: center; }
.nav-links a { color: var(--muted); text-decoration: none; font-size: 0.85rem; font-weight: 500; padding: 6px 14px; border-radius: 6px; transition: all 0.3s; letter-spacing: 0.3px; }
.nav-links a:hover, .nav-links a.active { color: var(--accent); background: rgba(232,184,75,0.08); }
.nav-login-btn { background: var(--accent) !important; color: var(--navy) !important; font-weight: 600 !important; padding: 7px 18px !important; }
.nav-login-btn:hover { background: var(--gold) !important; }

/* HERO */
#page-home { z-index: 2; }
.hero { min-height: 100vh; display: flex; align-items: center; justify-content: center; position: relative; overflow: hidden; padding: 100px 40px 60px; }
.hero-bg { position: absolute; inset: 0; background: url('https://images.unsplash.com/photo-1523050854058-8df90110c9f1?w=1600&q=80') center/cover; filter: brightness(0.18) saturate(0.6); transform: scale(1.05); animation: heroPan 20s ease-in-out infinite alternate; }
@keyframes heroPan { from { transform: scale(1.05) translateX(0); } to { transform: scale(1.05) translateX(-2%); } }
.hero-content { position: relative; text-align: center; max-width: 780px; }
.hero-badge { display: inline-flex; align-items: center; gap: 8px; background: rgba(232,184,75,0.12); border: 1px solid rgba(232,184,75,0.3); color: var(--accent); font-size: 0.75rem; font-weight: 600; letter-spacing: 2px; text-transform: uppercase; padding: 6px 16px; border-radius: 999px; margin-bottom: 28px; animation: fadeUp 0.8s 0.2s both; }
.hero h1 { font-family: 'Playfair Display', serif; font-size: clamp(2.8rem, 7vw, 5.5rem); font-weight: 900; line-height: 1.08; color: var(--white); margin-bottom: 22px; animation: fadeUp 0.8s 0.4s both; }
.hero h1 span { color: var(--accent); }
.hero p { font-size: 1.1rem; color: var(--text); line-height: 1.8; margin-bottom: 38px; animation: fadeUp 0.8s 0.6s both; }
.hero-cta { display: flex; gap: 14px; justify-content: center; flex-wrap: wrap; animation: fadeUp 0.8s 0.8s both; }
.btn-primary { background: var(--accent); color: var(--navy); font-weight: 700; padding: 14px 32px; border: none; border-radius: 8px; font-size: 0.95rem; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.3s; letter-spacing: 0.3px; }
.btn-primary:hover { background: var(--gold); transform: translateY(-2px); box-shadow: 0 8px 30px rgba(232,184,75,0.3); }
.btn-outline { background: transparent; color: var(--white); font-weight: 600; padding: 14px 32px; border: 1.5px solid rgba(255,255,255,0.25); border-radius: 8px; font-size: 0.95rem; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.3s; }
.btn-outline:hover { border-color: var(--accent); color: var(--accent); transform: translateY(-2px); }
.stats-strip { display: flex; justify-content: center; gap: 0; margin-top: 70px; flex-wrap: wrap; animation: fadeUp 0.8s 1s both; }
.stat-item { padding: 22px 44px; border-right: 1px solid rgba(255,255,255,0.08); text-align: center; }
.stat-item:last-child { border-right: none; }
.stat-item .num { font-family: 'Playfair Display', serif; font-size: 2.4rem; font-weight: 900; color: var(--accent); line-height: 1; }
.stat-item .label { font-size: 0.78rem; color: var(--muted); text-transform: uppercase; letter-spacing: 1.5px; margin-top: 4px; }
@keyframes fadeUp { from { opacity: 0; transform: translateY(28px); } to { opacity: 1; transform: translateY(0); } }

/* SECTIONS */
.section { padding: 80px 40px; max-width: 1200px; margin: 0 auto; }
.section-label { font-size: 0.72rem; font-weight: 700; letter-spacing: 3px; text-transform: uppercase; color: var(--accent); margin-bottom: 10px; }
.section-title { font-family: 'Playfair Display', serif; font-size: clamp(1.9rem, 4vw, 3rem); font-weight: 900; color: var(--white); margin-bottom: 16px; line-height: 1.2; }
.section-sub { font-size: 1rem; color: var(--muted); max-width: 580px; line-height: 1.75; margin-bottom: 48px; }
.cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 22px; }
.card { background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 16px; overflow: hidden; transition: all 0.35s; backdrop-filter: blur(6px); cursor: default; }
.card:hover { transform: translateY(-6px); border-color: rgba(232,184,75,0.4); box-shadow: 0 20px 50px rgba(0,0,0,0.4); }
.card-img { width: 100%; height: 190px; object-fit: cover; display: block; transition: transform 0.4s; }
.card:hover .card-img { transform: scale(1.04); }
.card-body { padding: 22px; }
.card-body h3 { font-family: 'Playfair Display', serif; font-size: 1.15rem; color: var(--white); margin-bottom: 8px; }
.card-body p { font-size: 0.88rem; color: var(--muted); line-height: 1.7; }
.card-tag { display: inline-block; font-size: 0.7rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--accent); background: rgba(232,184,75,0.1); padding: 3px 10px; border-radius: 999px; margin-bottom: 10px; }
.teacher-card { background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 16px; padding: 28px 24px; text-align: center; transition: all 0.35s; backdrop-filter: blur(6px); }
.teacher-card:hover { transform: translateY(-5px); border-color: rgba(232,184,75,0.4); }
.teacher-avatar { width: 80px; height: 80px; border-radius: 50%; background: linear-gradient(135deg, var(--blue), var(--accent)); display: flex; align-items: center; justify-content: center; font-size: 1.8rem; margin: 0 auto 16px; font-weight: 700; color: var(--white); font-family: 'Playfair Display', serif; }
.teacher-card h3 { color: var(--white); font-size: 1rem; font-weight: 600; margin-bottom: 4px; }
.teacher-card p { color: var(--muted); font-size: 0.82rem; }
.teacher-card .subj { color: var(--accent); font-weight: 600; font-size: 0.8rem; margin-top: 6px; }
.gallery-grid { display: grid; grid-template-columns: repeat(4, 1fr); grid-template-rows: repeat(2, 200px); gap: 14px; }
.gallery-grid img { width: 100%; height: 100%; object-fit: cover; border-radius: 12px; transition: all 0.35s; cursor: pointer; }
.gallery-grid img:first-child { grid-column: span 2; grid-row: span 2; height: 100%; }
.gallery-grid img:hover { transform: scale(1.02); filter: brightness(1.1); }
.event-card { display: flex; gap: 22px; align-items: flex-start; background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 14px; padding: 24px; margin-bottom: 16px; transition: all 0.3s; backdrop-filter: blur(6px); }
.event-card:hover { transform: translateX(6px); border-color: rgba(232,184,75,0.4); }
.event-date { min-width: 60px; text-align: center; background: rgba(232,184,75,0.12); border-radius: 10px; padding: 12px 8px; }
.event-date .day { font-family: 'Playfair Display', serif; font-size: 1.8rem; font-weight: 900; color: var(--accent); line-height: 1; }
.event-date .month { font-size: 0.7rem; font-weight: 700; letter-spacing: 1.5px; text-transform: uppercase; color: var(--muted); margin-top: 2px; }
.event-info h3 { color: var(--white); font-size: 1rem; font-weight: 600; margin-bottom: 5px; }
.event-info p { color: var(--muted); font-size: 0.85rem; line-height: 1.6; }

/* AUTH */
#page-auth { background: var(--navy); display: flex; align-items: center; justify-content: center; min-height: 100vh; padding: 20px; }
.auth-container { width: 100%; max-width: 480px; position: relative; z-index: 1; }
.auth-logo { text-align: center; margin-bottom: 36px; }
.auth-logo .icon { width: 64px; height: 64px; background: linear-gradient(135deg, var(--blue), var(--accent)); border-radius: 18px; display: flex; align-items: center; justify-content: center; margin: 0 auto 14px; font-size: 1.6rem; }
.auth-logo h2 { font-family: 'Playfair Display', serif; font-size: 1.5rem; color: var(--white); }
.auth-logo p { color: var(--muted); font-size: 0.85rem; margin-top: 4px; }
.auth-tabs { display: flex; background: rgba(255,255,255,0.04); border-radius: 10px; padding: 4px; margin-bottom: 28px; border: 1px solid rgba(255,255,255,0.08); }
.auth-tab { flex: 1; padding: 10px; text-align: center; font-weight: 600; font-size: 0.88rem; cursor: pointer; border-radius: 8px; transition: all 0.3s; color: var(--muted); border: none; background: transparent; font-family: 'DM Sans', sans-serif; }
.auth-tab.active { background: var(--accent); color: var(--navy); }
.auth-form-panel { display: none; animation: fadeUp 0.4s both; }
.auth-form-panel.active { display: block; }
.auth-card { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.08); border-radius: 18px; padding: 36px; backdrop-filter: blur(20px); }
.form-group { margin-bottom: 18px; }
.form-group label { display: block; font-size: 0.8rem; font-weight: 600; letter-spacing: 0.5px; color: var(--muted); margin-bottom: 7px; text-transform: uppercase; }
.form-group input, .form-group select { width: 100%; padding: 12px 16px; background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); border-radius: 8px; color: var(--white); font-size: 0.95rem; font-family: 'DM Sans', sans-serif; transition: all 0.3s; outline: none; }
.form-group input:focus, .form-group select:focus { border-color: var(--accent); background: rgba(232,184,75,0.05); }
.form-group select option { background: var(--deep); color: var(--white); }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
.submit-btn { width: 100%; padding: 14px; background: var(--accent); color: var(--navy); font-weight: 700; font-size: 0.95rem; border: none; border-radius: 8px; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.3s; margin-top: 6px; letter-spacing: 0.3px; }
.submit-btn:hover { background: var(--gold); transform: translateY(-1px); box-shadow: 0 8px 25px rgba(232,184,75,0.25); }
.demo-accounts { margin-top: 24px; padding-top: 22px; border-top: 1px solid rgba(255,255,255,0.07); }
.demo-title { font-size: 0.72rem; font-weight: 700; letter-spacing: 2px; text-transform: uppercase; color: var(--muted); margin-bottom: 12px; text-align: center; }
.demo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
.demo-btn { background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08); border-radius: 8px; padding: 10px 12px; cursor: pointer; transition: all 0.3s; text-align: left; }
.demo-btn:hover { border-color: var(--accent); background: rgba(232,184,75,0.06); }
.demo-btn .role { font-size: 0.73rem; font-weight: 700; color: var(--accent); text-transform: uppercase; letter-spacing: 0.8px; }
.demo-btn .creds { font-size: 0.75rem; color: var(--muted); margin-top: 2px; font-family: monospace; }
.back-home { text-align: center; margin-top: 18px; }
.back-home a { color: var(--muted); font-size: 0.82rem; cursor: pointer; transition: color 0.3s; text-decoration: none; }
.back-home a:hover { color: var(--accent); }

/* DASHBOARD */
#page-dashboard { background: var(--navy); min-height: 100vh; }
.dash-layout { display: flex; min-height: 100vh; }
.sidebar { width: 240px; background: rgba(255,255,255,0.025); border-right: 1px solid rgba(255,255,255,0.06); padding: 28px 16px; position: sticky; top: 0; height: 100vh; overflow-y: auto; flex-shrink: 0; }
.sidebar-logo { font-family: 'Playfair Display', serif; font-size: 1rem; font-weight: 900; color: var(--accent); padding: 0 8px 24px; border-bottom: 1px solid rgba(255,255,255,0.07); margin-bottom: 20px; }
.sidebar-user { display: flex; align-items: center; gap: 10px; padding: 12px; background: rgba(232,184,75,0.07); border-radius: 10px; margin-bottom: 28px; }
.sidebar-avatar { width: 38px; height: 38px; border-radius: 50%; background: linear-gradient(135deg, var(--blue), var(--accent)); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 0.95rem; color: white; }
.sidebar-user-info .name { font-size: 0.85rem; font-weight: 600; color: var(--white); }
.sidebar-user-info .role { font-size: 0.72rem; color: var(--accent); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; }
.sidebar-nav { list-style: none; }
.sidebar-nav li a { display: flex; align-items: center; gap: 10px; padding: 10px 14px; border-radius: 8px; color: var(--muted); font-size: 0.87rem; font-weight: 500; text-decoration: none; transition: all 0.3s; cursor: pointer; margin-bottom: 4px; }
.sidebar-nav li a:hover, .sidebar-nav li a.active { color: var(--white); background: rgba(255,255,255,0.06); }
.sidebar-nav li a.active { color: var(--accent); background: rgba(232,184,75,0.08); }
.sidebar-nav .icon { font-size: 1rem; width: 20px; text-align: center; }
.sidebar-nav .divider { height: 1px; background: rgba(255,255,255,0.06); margin: 14px 10px; }
.dash-main { flex: 1; padding: 36px 40px; overflow-y: auto; min-width: 0; }
.dash-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 36px; }
.dash-header h1 { font-family: 'Playfair Display', serif; font-size: 1.8rem; color: var(--white); }
.dash-header p { color: var(--muted); font-size: 0.85rem; margin-top: 3px; }
.logout-btn { background: rgba(255,80,80,0.12); border: 1px solid rgba(255,80,80,0.25); color: #ff6b6b; padding: 8px 18px; border-radius: 8px; cursor: pointer; font-size: 0.83rem; font-weight: 600; font-family: 'DM Sans', sans-serif; transition: all 0.3s; }
.logout-btn:hover { background: rgba(255,80,80,0.2); }
.kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px,1fr)); gap: 18px; margin-bottom: 36px; }
.kpi-card { background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 14px; padding: 22px; backdrop-filter: blur(8px); transition: all 0.3s; animation: fadeUp 0.5s both; }
.kpi-card:hover { transform: translateY(-3px); border-color: rgba(232,184,75,0.35); }
.kpi-card:nth-child(1){animation-delay:0.1s;} .kpi-card:nth-child(2){animation-delay:0.2s;} .kpi-card:nth-child(3){animation-delay:0.3s;} .kpi-card:nth-child(4){animation-delay:0.4s;}
.kpi-icon { font-size: 1.5rem; margin-bottom: 14px; }
.kpi-num { font-family: 'Playfair Display', serif; font-size: 2.1rem; font-weight: 900; color: var(--white); line-height: 1; }
.kpi-label { font-size: 0.78rem; color: var(--muted); margin-top: 5px; text-transform: uppercase; letter-spacing: 1px; }
.kpi-change { font-size: 0.75rem; color: #4ade80; margin-top: 8px; font-weight: 600; }
.kpi-change.down { color: #f87171; }
.dash-grid-2 { display: grid; grid-template-columns: 2fr 1fr; gap: 22px; margin-bottom: 22px; }
.dash-grid-equal { display: grid; grid-template-columns: 1fr 1fr; gap: 22px; }
.dash-widget { background: var(--card-bg); border: 1px solid var(--card-border); border-radius: 14px; padding: 24px; backdrop-filter: blur(8px); }
.widget-title { font-size: 0.85rem; font-weight: 700; color: var(--white); margin-bottom: 18px; text-transform: uppercase; letter-spacing: 0.8px; }
.announce-item { display: flex; gap: 14px; padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
.announce-item:last-child { border-bottom: none; }
.announce-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--accent); margin-top: 5px; flex-shrink: 0; }
.announce-item .title { font-size: 0.87rem; color: var(--white); font-weight: 500; }
.announce-item .time { font-size: 0.75rem; color: var(--muted); margin-top: 3px; }
.schedule-item { display: flex; align-items: center; gap: 12px; padding: 10px 0; border-bottom: 1px solid rgba(255,255,255,0.05); }
.schedule-item:last-child { border-bottom: none; }
.sched-time { font-size: 0.75rem; font-weight: 700; color: var(--accent); min-width: 50px; font-family: monospace; }
.sched-subj { font-size: 0.85rem; color: var(--white); font-weight: 500; }
.sched-room { font-size: 0.75rem; color: var(--muted); }
.progress-row { margin-bottom: 14px; }
.progress-row .label-row { display: flex; justify-content: space-between; margin-bottom: 6px; }
.progress-row .subj { font-size: 0.82rem; color: var(--text); font-weight: 500; }
.progress-row .pct { font-size: 0.82rem; color: var(--accent); font-weight: 700; }
.progress-bar { height: 6px; background: rgba(255,255,255,0.07); border-radius: 999px; overflow: hidden; }
.progress-fill { height: 100%; border-radius: 999px; background: linear-gradient(90deg, var(--accent), var(--gold)); transition: width 1s ease; }

/* ─── STAFF MANAGEMENT STYLES ─── */
.staff-section { display: none; }
.staff-section.active { display: block; }

.staff-tabs { display: flex; gap: 8px; margin-bottom: 28px; flex-wrap: wrap; }
.staff-tab-btn { padding: 9px 18px; border-radius: 8px; border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.04); color: var(--muted); font-size: 0.83rem; font-weight: 600; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: all 0.3s; }
.staff-tab-btn:hover { border-color: var(--accent); color: var(--accent); }
.staff-tab-btn.active { background: var(--accent); color: var(--navy); border-color: var(--accent); }

.staff-panel { display: none; }
.staff-panel.active { display: block; animation: fadeUp 0.3s both; }

/* Staff directory table */
.staff-table-wrap { overflow-x: auto; border-radius: 12px; border: 1px solid var(--card-border); }
.staff-table { width: 100%; border-collapse: collapse; font-size: 0.85rem; }
.staff-table th { background: rgba(232,184,75,0.08); color: var(--accent); font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; padding: 14px 16px; text-align: left; border-bottom: 1px solid var(--card-border); white-space: nowrap; }
.staff-table td { padding: 13px 16px; color: var(--text); border-bottom: 1px solid rgba(255,255,255,0.04); vertical-align: middle; }
.staff-table tr:last-child td { border-bottom: none; }
.staff-table tr:hover td { background: rgba(255,255,255,0.03); }
.staff-avatar-sm { width: 34px; height: 34px; border-radius: 50%; background: linear-gradient(135deg, var(--blue), var(--accent)); display: flex; align-items: center; justify-content: center; font-size: 0.75rem; font-weight: 700; color: white; flex-shrink: 0; overflow: hidden; }
.staff-avatar-sm img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
.staff-name-cell { display: flex; align-items: center; gap: 10px; }
.staff-name-cell .sname { font-weight: 600; color: var(--white); font-size: 0.87rem; }
.staff-name-cell .semail { font-size: 0.75rem; color: var(--muted); }

.badge { display: inline-block; padding: 3px 10px; border-radius: 999px; font-size: 0.7rem; font-weight: 700; letter-spacing: 0.5px; text-transform: uppercase; }
.badge-teacher { background: rgba(96,165,250,0.15); color: #60a5fa; }
.badge-staff { background: rgba(167,139,250,0.15); color: #a78bfa; }
.badge-admin { background: rgba(232,184,75,0.15); color: var(--accent); }
.badge-active { background: rgba(74,222,128,0.12); color: #4ade80; }
.badge-inactive { background: rgba(248,113,113,0.12); color: #f87171; }
.badge-onleave { background: rgba(251,191,36,0.12); color: #fbbf24; }

.action-btns { display: flex; gap: 6px; }
.action-btn { width: 30px; height: 30px; border-radius: 6px; border: none; cursor: pointer; display: flex; align-items: center; justify-content: center; font-size: 0.85rem; transition: all 0.2s; }
.action-btn.edit { background: rgba(96,165,250,0.12); color: #60a5fa; }
.action-btn.edit:hover { background: rgba(96,165,250,0.25); }
.action-btn.del { background: rgba(248,113,113,0.12); color: #f87171; }
.action-btn.del:hover { background: rgba(248,113,113,0.25); }
.action-btn.view { background: rgba(74,222,128,0.12); color: #4ade80; }
.action-btn.view:hover { background: rgba(74,222,128,0.25); }

/* Search bar */
