// ─── ATTENDANCE ───
function renderAttendance() {
  const months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
  const now = new Date();
  document.getElementById('attend-month-label').textContent = months[now.getMonth()] + ' ' + now.getFullYear();
  const grid = document.getElementById('attend-grid');
  grid.innerHTML = STAFF.map(s => {
    const att = ATTENDANCE[s.id] || Array(22).fill('present');
    const initials = s.name.split(' ').filter(w=>w.length>1).map(w=>w[0]).join('').toUpperCase().slice(0,2);
    const pct = Math.round((att.filter(d=>d==='present').length / att.length)*100);
    return `
      <div class="attend-card">
        <div class="attend-header">
          <div class="a-avatar">${initials}</div>
          <div><div class="a-name">${s.name}</div><div class="a-role">${s.role}</div></div>
          <div style="margin-left:auto;"><div class="attend-pct">${pct}%</div></div>
        </div>
        <div class="attend-row">
          ${att.map((d,i) => `<div class="attend-day ${d}" title="Day ${i+1}: ${d}" onclick="toggleAttend(${s.id}, ${i})">${i+1}</div>`).join('')}
        </div>
        <div style="display:flex;gap:12px;font-size:0.72rem;color:var(--muted);">
          <span style="color:#4ade80;">● ${att.filter(d=>d==='present').length} Present</span>
          <span style="color:#f87171;">● ${att.filter(d=>d==='absent').length} Absent</span>
          <span style="color:#fbbf24;">● ${att.filter(d=>d==='leave').length} Leave</span>
        </div>
      </div>`;
  }).join('');
}

function toggleAttend(staffId, dayIdx) {
  if(!ATTENDANCE[staffId]) ATTENDANCE[staffId] = Array(22).fill('present');
  const cycle = ['present','absent','leave'];
  const cur = ATTENDANCE[staffId][dayIdx];
  const next = cycle[(cycle.indexOf(cur)+1) % cycle.length];
  ATTENDANCE[staffId][dayIdx] = next;
  renderAttendance();
  renderStaffStats();
}

// ─── PAYROLL ───
function renderPayroll() {
  const total = STAFF.reduce((a,s)=>a+s.salary,0);
  const teachTotal = STAFF.filter(s=>s.type==='Teacher').reduce((a,s)=>a+s.salary,0);
  const ntTotal = STAFF.filter(s=>s.type==='Non-Teaching').reduce((a,s)=>a+s.salary,0);
  const paid = STAFF.filter(s=>s.status==='Active').length;

  document.getElementById('pay-total').textContent = total.toLocaleString() + ' RWF';
  document.getElementById('pay-teachers').textContent = teachTotal.toLocaleString() + ' RWF';
  document.getElementById('pay-nonteach').textContent = ntTotal.toLocaleString() + ' RWF';
  document.getElementById('pay-paid').textContent = paid + ' / ' + STAFF.length;

  const tbody = document.getElementById('payroll-table-body');
  tbody.innerHTML = STAFF.map(s => {
    const deduct = Math.round(s.salary * 0.05);
    const net = s.salary - deduct;
    const isPaid = s.status === 'Active';
    return `<tr>
      <td style="color:var(--white);font-weight:600;">${s.name}</td>
      <td style="color:var(--muted);font-size:0.82rem;">${s.role}</td>
      <td class="pay-amount" style="color:var(--text);">${s.salary.toLocaleString()} RWF</td>
      <td style="color:#f87171;font-size:0.83rem;">-${deduct.toLocaleString()} RWF</td>
      <td class="pay-amount">${net.toLocaleString()} RWF</td>
      <td><span class="badge ${isPaid?'badge-active':'badge-inactive'}">${isPaid ? 'Paid' : 'Pending'}</span></td>
      <td><button class="action-btn view" style="width:auto;padding:0 10px;" onclick="showToast('Payslip generated for ${s.name}! 💰')">Payslip</button></td>
    </tr>`;
  }).join('');
}

// ─── CONTRACTS ───
function renderContracts() {
  const list = document.getElementById('contracts-list');
  list.innerHTML = STAFF.map(s => {
    const yr = s.joined ? new Date(s.joined).getFullYear() : '—';
    const expYear = yr !== '—' ? yr + 5 : '—';
    return `
      <div class="contract-card">
        <div class="contract-icon">📄</div>
        <div class="contract-info">
          <h4>${s.name} — Employment Contract</h4>
          <p>${s.role} · ${s.dept} Department · Since ${formatDate(s.joined)} · Contract valid until Dec ${expYear}</p>
        </div>
        <div class="contract-actions">
          <button class="action-btn view" title="View" onclick="showToast('Contract opened for ${s.name} 📄')">👁️</button>
          <button class="action-btn edit" title="Renew" onclick="showToast('Contract renewal initiated for ${s.name} ✅')">🔄</button>
          <button class="action-btn del" title="Archive" onclick="showToast('Contract archived for ${s.name}')">📁</button>
        </div>
      </div>`;
  }).join('');
}

// ─── CONTACT ───
function handleContact() {
  const name = document.getElementById('c-name').value.trim();
  const email = document.getElementById('c-email').value.trim();
  if (!name || !email) return showToast('Please fill in at least your name and email.', true);
  showToast("Message sent! We'll respond within 24 hours. ✅");
  ['c-name','c-email','c-subj','c-msg'].forEach(id => document.getElementById(id).value = '');
}

// ─── TOAST ───
function showToast(msg, isError = false) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (isError ? ' error' : '');
  setTimeout(() => t.className = 'toast', 3500);
}

// ─── COUNTERS ───
function initCounters() {
  document.querySelectorAll('.counter').forEach(el => {
    const target = +el.dataset.target;
    let cur = 0;
    const step = Math.ceil(target / 60);
    const tick = setInterval(() => {
      cur = Math.min(cur + step, target);
      el.textContent = cur.toLocaleString() + (target >= 1000 ? '+' : (target === 60 ? '+' : ''));
      if (cur >= target) clearInterval(tick);
    }, 20);
  });
}

// ─── SCROLL REVEAL ───
function initReveal() {
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) e.target.classList.add('visible'); });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el => obs.observe(el));
}

// ─── BOOT ───
window.addEventListener('load', () => {
  setTimeout(() => {
    document.getElementById('loading-screen').classList.add('done');
    initReveal();
    // Show all panels except staff by default
    document.querySelectorAll('.dash-panel').forEach(p => p.style.display = 'none');
    document.getElementById('panel-overview').style.display = 'block';
  }, 1200);
});
</script>
